DATABASE_URL="postgresql://postgres:postgres@localhost:5432/github_hotboard"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
GITHUB_ID="github-oauth-app-client-id"
GITHUB_SECRET="github-oauth-app-client-secret"
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_TTS_MODEL="gpt-4o-mini-tts"
EXPORT_ROOT="./data/exports"
VIDEO_INLINE_RENDER="false"

# z.ai (Zhipu AI)
ZAI_API_KEY=""
ZAI_BASE_URL="https://api.z.ai/api/paas/v4"
ZAI_CHAT_MODEL="glm-4.7"
ZAI_TTS_VOICE="tongtong"

# Volcengine Ark / Doubao
ARK_API_KEY=""
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_TEXT_MODEL="doubao-seed-2-0-mini-260215"
ARK_VISION_MODEL="doubao-seed-2-0-mini-260215"
ARK_TTS_MODEL="doubao-tts"
ARK_TTS_VOICE="alloy"
ARK_VIDEO_MODEL="doubao-seedance-1-5-pro"
ARK_VIDEO_GENERATION_PATH="/contents/generations/tasks"
ARK_VIDEO_QUERY_PATH_TEMPLATE="/contents/generations/tasks/{taskId}"
ARK_DEMO_IMAGE_URL=""
ARK_DEMO_PROMPT="你看见了什么？"

# Provider selection: "openai" | "zai" | "ark"
AI_TEXT_PROVIDER="ark"
# TTS provider: "openai" | "zai" | "ark" | "none"
AI_TTS_PROVIDER="none"
# Video clip provider: "ark" | "none"
AI_VIDEO_CLIP_PROVIDER="ark"
