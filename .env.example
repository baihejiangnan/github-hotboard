DATABASE_URL="postgresql://postgres:postgres@localhost:5432/github_hotboard"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
GITHUB_ID="github-oauth-app-client-id"
GITHUB_SECRET="github-oauth-app-client-secret"
EXPORT_ROOT="./data/exports"
FFMPEG_BINARY_PATH="ffmpeg"
VIDEO_INLINE_RENDER="false"

# Volcengine Ark / Doubao
ARK_API_KEY=""
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_TEXT_MODEL="doubao-seed-2-0-mini-260215"
ARK_VISION_MODEL="doubao-seed-2-0-mini-260215"
ARK_DEMO_IMAGE_URL=""
ARK_DEMO_PROMPT="你看见了什么？"

# Provider selection: "openai" | "zai" | "ark"
AI_TEXT_PROVIDER="ark"

# Local-first media pipeline
# TTS provider: "piper" | "openai" | "zai" | "ark" | "none"
AI_TTS_PROVIDER="piper"
# Video clip provider: "none" | "ark"
AI_VIDEO_CLIP_PROVIDER="none"

# Piper runtime and voices - all files stay inside this repo
WORKSPACE_TOOLS_ROOT="./tools"
WORKSPACE_MODELS_ROOT="./models"
PIPER_ROOT="./tools/piper"
PIPER_DOWNLOADS_ROOT="./tools/piper/downloads"
PIPER_INSTALL_ROOT="./tools/piper/runtime"
PIPER_BINARY_PATH="./tools/piper/runtime/piper/piper.exe"
PIPER_VOICES_ROOT="./models/piper"
PIPER_VOICE_NAME="zh_CN-huayan-medium"
PIPER_VOICE_MODEL_PATH="./models/piper/zh_CN-huayan-medium.onnx"
PIPER_VOICE_CONFIG_PATH="./models/piper/zh_CN-huayan-medium.onnx.json"
PIPER_RELEASE_VERSION="2023.11.14-2"
PIPER_DOWNLOAD_URL="https://github.com/rhasspy/piper/releases/download/2023.11.14-2/piper_windows_amd64.zip"
PIPER_VOICE_MODEL_URL="https://huggingface.co/rhasspy/piper-voices/resolve/main/zh/zh_CN/huayan/medium/zh_CN-huayan-medium.onnx?download=true"
PIPER_VOICE_CONFIG_URL="https://huggingface.co/rhasspy/piper-voices/resolve/main/zh/zh_CN/huayan/medium/zh_CN-huayan-medium.onnx.json?download=true"

# Optional cloud fallbacks
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_TTS_MODEL="gpt-4o-mini-tts"
